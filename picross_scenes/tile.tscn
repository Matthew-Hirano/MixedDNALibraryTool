[sub_resource type="GDScript" id="GDScript_vx4y2"]
script/source = "extends Panel

@onready var target : bool
@onready var record = []

var marked : bool = false
var is_chiseled : bool = false

signal erase_signal(id, bo)
signal chisel_signal(id, bo)
signal mark_signal(id, bo)

func _ready() -> void:
	$Mark.visible = false
	self.set_custom_minimum_size(get_node('AnimatedSprite2D/Control').get_size())
	$Button.set_custom_minimum_size(get_node('AnimatedSprite2D/Control').get_size())

func fadein(delay:float) -> void:
	$AnimatedSprite2D.modulate.a = 0
	await get_tree().create_timer(delay).timeout
	var tween = get_tree().create_tween()
	tween.tween_property($AnimatedSprite2D, \"modulate:a\", 1, 0.2)
	
func fadeout( delay:float, final_color : Color ) -> void:
	await get_tree().create_timer(delay).timeout
	$AnimatedSprite2D.animation = 'default'
	var tween = get_tree().create_tween()
	tween.tween_property($AnimatedSprite2D, \"modulate\", final_color, 0.2)
	var tween2 = get_tree().create_tween()
	tween2.tween_property(self.get_theme_stylebox(\"panel\"), \"border_color\", Color(0,0,0,0), 0.2)
	
func _on_button_gui_input(event: InputEvent) -> void:
	if Controls.active:
		if event is InputEventMouseButton and event.pressed:
			match event.button_index:
				MOUSE_BUTTON_LEFT:
					chiseled(true, false)
					Controls.clicked = true
				MOUSE_BUTTON_RIGHT:
					mark(true, false)
					Controls.rightclicked = true
		elif Input.is_action_just_released(\"mouse_left\"):
			Controls.clicked = false
		elif Input.is_action_just_released(\"mouse_right\"):
			Controls.rightclicked = false
	
func mark(firstpress:bool, redo:bool) -> void:
	if !marked:
		record.append('mark')
		if len(record) > 100:
			record.pop_front()
		marked = true
		is_chiseled = false
		mark_signal.emit(self, redo)
		get_node('AnimatedSprite2D').animation = 'default'
		get_node('Mark').visible = true
		#get_node('Sprite2D').region_rect.position.x = 24
		if firstpress and !redo:
			Controls.mode = \"Mark\"
	elif firstpress:
		erase(true, redo)

func erase(firstpress:bool, redo:bool) -> void:
	if marked or is_chiseled:
		record.append('erase')
		if len(record) > 100:
			record.pop_front()
		marked = false
		is_chiseled = false
		erase_signal.emit(self, redo)
		#get_node('Sprite2D').region_rect.position.x = 0
		get_node('AnimatedSprite2D').animation = 'default'
		get_node('Mark').visible = false
		if firstpress and !redo:
			Controls.mode = \"Erase\"

func chiseled(firstpress:bool, redo:bool) -> void:
	if !is_chiseled:
		record.append('chiseled')
		if len(record) > 100:
			record.pop_front()
		is_chiseled = true
		marked = false
		chisel_signal.emit(self, redo)
		#get_node('Sprite2D').region_rect.position.x = 12
		get_node('AnimatedSprite2D').animation = 'chiseled'
		get_node('Mark').visible = false
		if firstpress and !redo:
			Controls.mode = 'Chisel'
	elif firstpress:
		erase(true, redo)

func _on_button_mouse_entered() -> void:
	if Controls.clicked:
		if Controls.mode == 'Chisel':
			chiseled(false, false)
		elif Controls.mode == 'Erase':
			erase(false, false)
	elif Controls.rightclicked:
		if Controls.mode == 'Mark':
			mark(false, false)
		elif Controls.mode == 'Erase':
			erase(false, false)
			
"

