[sub_resource type="GDScript" id="GDScript_rq8yp"]
script/source = "extends Panel

@onready var time_elapsed = 0.0
var paused = false

func _process(delta: float):
	if !paused:
		time_elapsed += delta
		
		var mins = int(time_elapsed) / 60
		var secs = int(time_elapsed) % 60
		
		$Label.set_text(str(\"%0*d\" % [2, mins]) + \" \" + str(\"%0*d\" % [2, secs])) #: is not accepted in html font
"

