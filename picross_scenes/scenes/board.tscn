[sub_resource type="GDScript" id="GDScript_4mug4"]
script/source = "extends Control

@export var pre_image : Texture2D = load('res://picross_scenes/images/trex.png')
@export var pre_color : Texture2D = load('res://picross_scenes/images/trex_color.png')
@export var solution : String = 'FILLER'

@onready var image = pre_image.get_image()
@onready var color_image = pre_color.get_image()

var tile : PackedScene = preload(\"res://picross_scenes/tile.tscn\")
var hint : PackedScene = preload(\"res://picross_scenes/hint.tscn\")

var tilesize = Controls.tilesize
var rowhints : Array = []
var colhints : Array = []
var flip : bool = true
var bgcolor1 = Color(1,1,1,1)
var bgcolor2 = Color(0.9,0.9,0.9,1)

var max_h : Array = []
var max_v : Array = []

var runningdelay : float = 0.0
var color_array : Array

func _process(_delta: float) -> void:
	for child in get_node('PuzzleBox/UberContainer/TileContainer').get_children():
		if child.target and !child.is_chiseled: #Board is not solved
			return
		elif !child.target and child.is_chiseled:
			return
	#Board is solved
	solved()

func _ready():
	Controls.active = true
	image.decompress()
	#Determine the number of columns and rows, and generate the hints
	var z : Array = _image_to_matrix(image)
	color_array = _image_to_color(color_image)
	for row in z:
		var h = _row_to_hint(row)
		rowhints.append(h)
		max_h.append(len(h))
	for col in _transposed_matrix(z):
		var v = _col_to_hint(col)
		colhints.append(v)
		max_v.append(len(v))
	#Populate the grid with tile and hint scenes
	get_node('PuzzleBox/UberContainer/TileContainer').set_columns(len(z[0]))
	get_node(\"PuzzleBox/UberContainer/Cursor\").tile_boundary = Vector2(len(z[0]),len(z)) * tilesize
	get_node('PuzzleBox/UberContainer/HHintContainer/HHints').set_columns(max_h.max())
	get_node('PuzzleBox/UberContainer/Cursor').up_boundary = -tilesize * max_v.max()
	get_node('PuzzleBox/UberContainer/Cursor').left_boundary = -tilesize * max_h.max()
	get_node('PuzzleBox/UberContainer/Filler/FillerBottom/HowToPlay').visible = true
	get_node('PuzzleBox/UberContainer/Filler/FillerBottom/Buttons').visible = true
	get_node('PuzzleBox/UberContainer/Filler/FillerBottom/Label').visible = false
	get_node('PuzzleBox/UberContainer/Filler/FillerBottom/Label').text = solution
	for y in range(len(z)):
		#Add filler
		var fill = hint.instantiate()
		if flip:
			fill.get_theme_stylebox(\"panel\").bg_color = bgcolor2
		fill.get_theme_stylebox(\"panel\").corner_radius_top_left = 5
		fill.get_theme_stylebox(\"panel\").corner_radius_bottom_left = 5
		fill.inactive = true
		get_node('PuzzleBox/UberContainer/HHintContainer/Filler').add_child(fill)
		#Add row hints
		for d in range(max_h.max()-len(rowhints[y])):
			var h = hint.instantiate()
			if flip:
				h.get_theme_stylebox(\"panel\").bg_color = bgcolor2
			h.inactive = true
			get_node('PuzzleBox/UberContainer/HHintContainer/HHints').add_child(h)
		for e in range(len(rowhints[y])):
			var h = hint.instantiate()
			if flip:
				h.get_theme_stylebox(\"panel\").bg_color = bgcolor2
			var hintnumbers : String = str(rowhints[y][e])
			h.get_node('RichTextLabel').text = hintnumbers
			get_node('PuzzleBox/UberContainer/HHintContainer/HHints').add_child(h)
			h.erase_signal.connect(get_node('PuzzleBox/UberContainer/Cursor').on_erase_signal)
			h.mark_signal.connect(get_node('PuzzleBox/UberContainer/Cursor').on_mark_signal)
		if flip:
			flip = false
		else:
			flip = true

		#Add real tiles
		for x in range(len(z[0])):
			var q = tile.instantiate()
			if (x+1) % 5 == 0:
				#q.get_theme_stylebox(\"panel\").set_border_color(Color(1,1,1,1))
				q.get_theme_stylebox(\"panel\").border_width_right = 2
			elif (x) % 5 == 0:
				q.get_theme_stylebox(\"panel\").border_width_left = 2
			if (y) % 5 == 0:
				q.get_theme_stylebox(\"panel\").border_width_top = 2
			elif (y+1) % 5 == 0:
				q.get_theme_stylebox(\"panel\").border_width_bottom = 2 
			if z[y][x] == 1:
				q.target = true
			else:
				q.target = false
			get_node('PuzzleBox/UberContainer/TileContainer').add_child(q)
			q.erase_signal.connect(get_node('PuzzleBox/UberContainer/Cursor').on_erase_signal)
			q.mark_signal.connect(get_node('PuzzleBox/UberContainer/Cursor').on_mark_signal)
			q.chisel_signal.connect(get_node('PuzzleBox/UberContainer/Cursor').on_chisel_signal)
			q.fadein(runningdelay)
			runningdelay += 0.004
	#Add column hints
	for x in range(len(z[0])):
		var fill = hint.instantiate()
		if flip:
			fill.get_theme_stylebox(\"panel\").bg_color = bgcolor2
		fill.get_theme_stylebox(\"panel\").corner_radius_top_left = 5
		fill.get_theme_stylebox(\"panel\").corner_radius_top_right = 5
		fill.inactive = true
		get_node('PuzzleBox/UberContainer/VHintContainer/Filler').add_child(fill)
		
		var single_column = VBoxContainer.new()
		single_column.add_theme_constant_override(\"separation\", 0)
		get_node('PuzzleBox/UberContainer/VHintContainer/VHints').add_child(single_column)
		
		for j in range(max_v.max()-len(colhints[x])):
			var h = hint.instantiate()
			if flip:
				h.get_theme_stylebox(\"panel\").bg_color = bgcolor2
			h.inactive = true
			get_node('PuzzleBox/UberContainer/VHintContainer/VHints').get_child(x).add_child(h)
		for k in range(len(colhints[x])):
			var h = hint.instantiate()
			if flip:
				h.get_theme_stylebox(\"panel\").bg_color = bgcolor2
			var hintnumbers : String = str(colhints[x][k])
			h.get_node('RichTextLabel').text = hintnumbers
			get_node('PuzzleBox/UberContainer/VHintContainer/VHints').get_child(x).add_child(h)
			h.erase_signal.connect(get_node('PuzzleBox/UberContainer/Cursor').on_erase_signal)
			h.mark_signal.connect(get_node('PuzzleBox/UberContainer/Cursor').on_mark_signal)
		if flip:
			flip = false
		else:
			flip = true
	$PuzzleBox.size.x = (len(z[0]) * tilesize) * 2
	$PuzzleBox.size.y = (len(z) * tilesize) * 2
	if get_parent() is Window:
		get_parent().size = $PuzzleBox.size

func _image_to_matrix( _image : Image ) -> Array:
	#Takes a transparent, square .png and converts into a matrix
	var matrix : Array = []
	for y in _image.get_size().y:
		var row : Array = []
		for x in _image.get_size().x:
			var current_pixel : Color = _image.get_pixel(x,y)
			if current_pixel == Color(0,0,0,1):
				row.append(1)
			else:
				row.append(0)
		matrix.append(row)
	return matrix
	
func _image_to_color( _image : Image ) -> Array:
	#Takes a transparent, square .png and converts into a matrix
	for y in _image.get_size().y:
		for x in _image.get_size().x:
			var current_pixel : Color = _image.get_pixel(x,y)
			color_array.append(current_pixel)
	return color_array
	
func _row_to_hint( row: Array ) -> Array:
	#Takes the matrix of the image and produces hints for each row from top to bottom
	var row_hint : Array = []
	var i = row.find(1)
	if i != -1:
		var c : int = 0
		while i < len(row):
			if row[i] != 0:
				c += 1
				i += 1
			else:
				if c > 0:
					row_hint.append(c)
				c = 0
				i += 1
		if c > 0:
			row_hint.append(c)
	else:
		row_hint.append(0)
	return row_hint
	
func _transposed_matrix( matrix: Array ):
	var transposed_array = []
	for x in len(matrix[0]):
		var new_array : Array = []
		for row in matrix:
			new_array.append(row[x])
		transposed_array.append(new_array)
	return transposed_array
	
func _col_to_hint( col : Array ) -> Array:
	var col_hint : Array = []
	var i : int = col.find(1)
	if i != -1:
		var c : int = 0
		while i < len(col):
			if col[i] != 0:
				c += 1
				i += 1
			else:
				if c > 0:
					col_hint.append(c)
				c = 0
				i += 1
		if c > 0:
			col_hint.append(c)
	else:
		col_hint.append(0)
	return col_hint

func erase_hints() -> void:
	for object in $PuzzleBox/UberContainer/TileContainer.get_children():
		object.set_modulate(Color(1,1,1,1))
	for container in $PuzzleBox/UberContainer/VHintContainer/VHints.get_children():
		for object in container.get_children():
			object.set_self_modulate(Color(1,1,1,1))
	for object in $PuzzleBox/UberContainer/VHintContainer/Filler.get_children():
		object.set_self_modulate(Color(1,1,1,1))
	for object in $PuzzleBox/UberContainer/HHintContainer/HHints.get_children():
		object.set_self_modulate(Color(1,1,1,1))
	for object in $PuzzleBox/UberContainer/HHintContainer/Filler.get_children():
		object.set_self_modulate(Color(1,1,1,1))

func solved():
	if Controls.active:
		Controls.active = false
		Controls.clicked = false
		Controls.rightclicked = false
		erase_hints()
		get_node('SND/complete').play()
		get_node('PuzzleBox/UberContainer/Cursor').visible = false
		get_node('PuzzleBox/UberContainer/Filler/FillerBottom/HowToPlay').visible = false
		get_node('PuzzleBox/UberContainer/Filler/FillerBottom/Buttons').visible = false
		get_node('PuzzleBox/UberContainer/Filler/FillerBottom/Label').visible = true
		for child in get_node('PuzzleBox/UberContainer/TileContainer').get_children():
			if child.marked:
				child.erase(false, false)
		$PuzzleBox/UberContainer/Filler/Timer.paused = true
		$PuzzleBox/UberContainer/Cursor.set_process_mode(PROCESS_MODE_DISABLED)
		$PuzzleBox/UberContainer/Filler/FillerBottom/Buttons/UNDO/Panel/Button.set_process_mode(PROCESS_MODE_DISABLED)
		$PuzzleBox/UberContainer/Filler/FillerBottom/Buttons/REDO/Panel/Button.set_process_mode(PROCESS_MODE_DISABLED)
		$PuzzleBox/UberContainer/Filler/FillerBottom/Buttons/CLEAR/Panel/Button.set_process_mode(PROCESS_MODE_DISABLED)
		
		runningdelay = 0.0
		for r in $PuzzleBox/UberContainer/TileContainer.get_children():
			if \"fadeout\" in r:
				r.fadeout( runningdelay, color_array.pop_front())
	#await get_tree().create_timer(1.1).timeout
	
func _unhandled_input(_event: InputEvent) -> void:
	#if Input.is_action_just_pressed(\"backspace\"):
	#	solved()
	pass
"

