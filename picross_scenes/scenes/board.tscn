script/source = "extends Button
@onready var tile_container: GridContainer = $\"../../../../../../TileContainer\"
@onready var cursor: Sprite2D = $\"../../../../../../Cursor\"

func _on_pressed() -> void:
	for i in tile_container.get_children():
		if \"erase\" in i:
			i.erase(false, false)
			i.record = []
	cursor.tile_record = []
	cursor.trash_record = []
	cursor.trash_tiles = []
"

