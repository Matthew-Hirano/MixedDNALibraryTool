[gd_scene load_steps=2 format=3 uid="uid://bjnho1nx8wenv"]

[sub_resource type="GDScript" id="GDScript_h2yge"]
script/source = "extends Window

@export var board : PackedScene = preload(\"res://picross_scenes/scenes/board.tscn\")

func _ready() -> void:
	self.visible = false

func _on_close_requested() -> void:
	self.queue_free()

func _on_nazo_spawn_puzzle_spawn( puzzle_key : String ) -> void:
	self.visible = true
	if puzzle_key in PuzzleIndex.puzzle_dict.keys():
		var puzzle = load( PuzzleIndex.puzzle_dict[puzzle_key][0] )
		var puzzle_color = load( PuzzleIndex.puzzle_dict[puzzle_key][1] )
		var new_puzzle = board.instantiate()
		new_puzzle.pre_image = puzzle
		new_puzzle.pre_color = puzzle_color
		new_puzzle.solution = puzzle_key
		self.add_child(new_puzzle)
"

[node name="Window" type="Window"]
auto_translate_mode = 1
position = Vector2i(200, 250)
wrap_controls = true
unresizable = true
content_scale_mode = 2
content_scale_aspect = 1
