script/source = "extends Button

const row : int = -1

@onready var spreadsheet: HBoxContainer = $\"../..\"

func _on_pressed() -> void:
	for obj in spreadsheet.get_children():
		var phix = obj.find_child(\"PhiX\")
		if phix != null:
			phix.queue_free()

func _ready() -> void:
	var f: StyleBoxFlat = get_theme_stylebox(\"focus\")
	f.expand_margin_bottom = 0
	f.expand_margin_left = 0
	f.expand_margin_right = 0
	f.expand_margin_top = 0
"

[sub_resource type="GDScript" id="GDScript_7kimb"]
script/source = "extends LineEdit

@onready var column_5: VBoxContainer = $\"../../../ScrollContainer/Spreadsheet/Column5\"
var prev_value : float

func _ready() -> void:
	$PopupPanel.modulate.a = 0
	$PanelContainer.visible = false

func _process(_delta: float) -> void:
	var running_sum : float = 0.0
	for line in column_5.get_children():
		if line is LineEdit:
			running_sum += float(line.text)
	self.text = str(running_sum)
	if running_sum != prev_value:
		if running_sum > 100:
			$PanelContainer.visible = true
			var tween = get_tree().create_tween()
			tween.tween_property($PopupPanel, \"modulate:a\", 1.0, 0.2)
		else:
			$PanelContainer.visible = false
			var tween = get_tree().create_tween()
			tween.tween_property($PopupPanel, \"modulate:a\", 0.0, 0.2)
		prev_value = running_sum
"

[sub_resource type="GDScript" id="GDScript_eudgn"]
script/source = "extends LineEdit

@onready var column_6: VBoxContainer = $\"../../../../ScrollContainer/Spreadsheet/Column6\"
@onready var final_vol: LineEdit = $\"../../../../HBoxContainer/DesiredVol/FinalVol\"
@onready var volunit: OptionButton = $\"../../../../HBoxContainer/Molunits2/LineEdit/Volunit\"
@onready var h_2o: LineEdit = $\"../../H2O/H2O\"
@onready var line_edit_3: LineEdit = $\"../../TotalLib/LineEdit3\"

@onready var panel1: PanelContainer = $PanelContainer
@onready var panel2: PanelContainer = $\"../../../../HBoxContainer/DesiredVol/FinalVol/PanelContainer\"

var prev_value : float

func _ready() -> void:
	panel1.visible = false
	panel2.visible = false
	$PopupPanel.modulate.a = 0

func _process(_delta: float) -> void:
	var running_sum : float = 0.0
	for line in column_6.get_children():
		if line is LineEdit:
			running_sum += float(line.text)
	self.text = str(running_sum)
	if running_sum != prev_value:
		if running_sum > (float(final_vol.text) / (0.001 * volunit.get_selected_id())):
			h_2o.text = \"nan\"
			line_edit_3.text = str(float(h_2o.text))
			var tween = get_tree().create_tween()
			tween.tween_property($PopupPanel, \"modulate:a\", 1.0, 0.2)
			panel1.visible = true
			panel2.visible = true
		else:
			h_2o.text = str((float(final_vol.text) / (0.001 * volunit.get_selected_id())) - float(running_sum))
			line_edit_3.text = str(float(h_2o.text) + running_sum)
			var tween = get_tree().create_tween()
			tween.tween_property($PopupPanel, \"modulate:a\", 0.0, 0.2)
			panel1.visible = false
			panel2.visible = false
		prev_value = running_sum
"

