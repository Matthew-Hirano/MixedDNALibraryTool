[sub_resource type="GDScript" id="GDScript_7fsio"]
script/source = "extends ColorRect

var tweens_running : bool
var previous_color1 : Color
var previous_color2 : Color
var new_color1: Color
var new_color2 : Color

func _ready() -> void:
	new_color1 = generate_random_rgb_color()
	new_color2 = generate_random_rgb_color()
	set_shaders_top(new_color1)
	set_shaders_bottom(new_color2)

func _process(_delta: float) -> void:
	if !tweens_running:
		tweens_running = true
		previous_color1 = new_color1
		previous_color2 = new_color2
		new_color1 = generate_random_rgb_color()
		new_color2 = generate_random_rgb_color()
		#print(\"old: \", previous_color1, previous_color2)
		#print(\"new: \", new_color1, new_color2)
		var tween = get_tree().create_tween()
		tween.tween_method(set_shaders_top, previous_color1, new_color1, 20)
		tween.tween_method(set_shaders_bottom, previous_color2, new_color2, 20)
		await tween.finished
		tweens_running = false
		
func set_shaders_top( new_color : Color ) -> void:
	self.material.set_shader_parameter(\"top_color\",new_color)
	
func set_shaders_bottom( new_color : Color ) -> void:
	self.material.set_shader_parameter(\"bottom_color\",new_color)
	
func generate_random_rgb_color() -> Color:
	return Color(
		randf_range(0.0,0.7), # RED
		randf_range(0.0,0.7), # GREEN
		randf_range(0.0,0.7), # BLUE
		)
"

