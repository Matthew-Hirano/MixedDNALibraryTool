[sub_resource type="GDScript" id="GDScript_k5hc1"]
script/source = "extends HBoxContainer

@onready var final_mol: LineEdit = $\"../../HBoxContainer/DesiredMol/FinalMol\"
@onready var final_vol: LineEdit = $\"../../HBoxContainer/DesiredVol/FinalVol\"
@onready var mol_unit: OptionButton = $\"../../HBoxContainer/Molunits/LineEdit/MolConc\"
@onready var vol_unit: OptionButton = $\"../../HBoxContainer/Molunits2/LineEdit/Volunit\"

@onready var new_row_num : PackedScene = preload(\"res://row_scenes/arrange_button.tscn\")
@onready var new_sample_button : PackedScene = preload(\"res://row_scenes/button.tscn\")
@onready var new_sample_name : PackedScene = preload(\"res://row_scenes/name.tscn\")
@onready var new_sample_length : PackedScene = preload(\"res://row_scenes/length.tscn\")
@onready var new_sample_concng : PackedScene = preload(\"res://row_scenes/concng.tscn\")
@onready var new_sample_ngunit : PackedScene = preload(\"res://row_scenes/mass_unit.tscn\")
@onready var new_sample_concnm : PackedScene = preload(\"res://row_scenes/concnm.tscn\")
@onready var new_sample_concmol : PackedScene = preload(\"res://row_scenes/m_unit.tscn\")
@onready var new_sample_libperc : PackedScene = preload(\"res://row_scenes/lib_percent.tscn\")
@onready var new_sample_vol : PackedScene = preload(\"res://row_scenes/voltoadd.tscn\")

var sample_dictionary : Dictionary
var row_number : int
var running_delta : float = 0

func _ready():
	row_number = 0
	_spawn_row()
	update_dict()

func update_dict() -> void:
	sample_dictionary = {}
	for obj in self.get_children():
		if obj.name != \"Column0\":
			for i in obj.get_children():
				if \"row\" in i:
					if i.row != 0:
						if i.row not in sample_dictionary:
							sample_dictionary[i.row] = []
						sample_dictionary[i.row].append(i)

func _process(_delta: float) -> void:
	running_delta += _delta
	if running_delta > 0.1:
		running_delta = 0
		update_dict()
		for i in sample_dictionary.keys():
			_calculate_molarity(i)

func _calculate_molarity( dictionary_index : int ):
	var concnm = float(sample_dictionary[dictionary_index][4].get_text())
	var libp = float(sample_dictionary[dictionary_index][-3].get_text())
	var final_m = float(final_mol.get_text()) * (mol_unit.get_selected_id())
	var final_v = float(final_vol.get_text()) / (vol_unit.get_selected_id())
	if final_m > 0 and final_v > 0:
		sample_dictionary[dictionary_index][-2].text = str( snappedf( ((final_m*(libp/100.0) / concnm) * final_v), 0.0001))
	else:
		return
		
func correct_units_nm( dictionary_index : int, _prev_index: int, _unit_index : int ) -> void:
	#if dictionary_index != -1:
		#var old_val = float(sample_dictionary[dictionary_index][4].get_text())
		#var new_val = str( snappedf( (old_val / pow(1000,(prev_index - unit_index)) ), 0.0001))
		#sample_dictionary[dictionary_index][4].text = new_val
	correct_concentration_ng( dictionary_index )

func correct_concentration_nm( dictionary_index : int ) -> void:
	if dictionary_index != -1:
		var leng = sample_dictionary[dictionary_index][1].get_text()
		var concng = sample_dictionary[dictionary_index][2].get_text()
		if len(concng) > 0 and len(leng) > 0:
			var convert_mass : float
			var convert_moles : float
			match sample_dictionary[dictionary_index][5].get_node(\"OptionButton\").selected:
				0:
					convert_moles = 0.001
				1:
					convert_moles = 1.0
				2:
					convert_moles = 1000.0
			match sample_dictionary[dictionary_index][3].get_node(\"OptionButton\").selected:
				0:
					convert_mass = 1.0
				1:
					convert_mass = 0.001
			#sample_dictionary[dictionary_index][4].text = str( snappedf( (float(concng) / (660*float(leng)) * convert_mass * convert_moles * 1000000), 0.0001))
			sample_dictionary[dictionary_index][4].text = str( snappedf( (float(concng) / ((615.94*float(leng))+36.04) * convert_mass * convert_moles * 1000000), 0.0001))
	
func correct_units_ng( dictionary_index : int, _prev_index: int, _unit_index : int ) -> void:
	#if dictionary_index != -1:
	#	var old_val = float(sample_dictionary[dictionary_index][2].get_text())
	#	var new_val = str( snappedf( (old_val / pow(1000,(prev_index - unit_index)) ), 0.0001))
	#	sample_dictionary[dictionary_index][2].text = new_val
	correct_concentration_nm( dictionary_index )
	
func correct_concentration_ng( dictionary_index : int ) -> void:
	if dictionary_index != -1:
		var leng = sample_dictionary[dictionary_index][1].get_text()
		var concnm = sample_dictionary[dictionary_index][4].get_text()
		if len(concnm) > 0 and len(leng) > 0:
			var convert_mass : float
			var convert_moles : float
			match sample_dictionary[dictionary_index][5].get_node(\"OptionButton\").selected:
				0:
					convert_moles = 0.001
				1:
					convert_moles = 1.0
				2:
					convert_moles = 1000.0
			match sample_dictionary[dictionary_index][3].get_node(\"OptionButton\").selected:
				0:
					convert_mass = 1.0
				1:
					convert_mass = 0.001
			#var intermediate_val = (float(concnm) * (660.0*float(leng)) / (convert_mass * convert_moles * 1000000.0))
			var intermediate_val = (float(concnm) * (36.04 + (615.94*float(leng))) / (convert_mass * convert_moles * 1000000.0))
			if intermediate_val > 1000:
				sample_dictionary[dictionary_index][2].text = str(  snappedf( intermediate_val, 0.1))
			else:
				sample_dictionary[dictionary_index][2].text = str(  snappedf( intermediate_val, 0.0001))
			
func _spawn_row():
	row_number += 1
	var row_num = new_row_num.instantiate()
	row_num.row = row_number
	$Column0.add_child(row_num)
	var sample_button = new_sample_button.instantiate()
	sample_button.text = ('-')
	sample_button.row = row_number
	if row_number == 1:
		sample_button.text = \"+\"
		#sample_button.set_modulate(Color(1,2,2))
		sample_button[\"theme_override_styles/normal\"].bg_color = Color(0.25, 0.56, 0.78)
	$Column7.add_child(sample_button)
	var sample_name = new_sample_name.instantiate()
	sample_name.row = row_number
	$Column1.add_child(sample_name)
	var sample_length = new_sample_length.instantiate()
	sample_length.row = row_number
	sample_length.len_changed.connect(correct_concentration_nm)
	$Column2.add_child(sample_length)
	var sample_concng = new_sample_concng.instantiate()
	sample_concng.row = row_number
	sample_concng.updated_ng.connect(correct_concentration_nm)
	$Column3.add_child(sample_concng)
	var sample_ngunit = new_sample_ngunit.instantiate()
	sample_ngunit.row = row_number
	sample_ngunit.updated_units.connect(correct_units_ng)
	$Column35.add_child(sample_ngunit)
	var sample_concnm = new_sample_concnm.instantiate()
	sample_concnm.row = row_number
	sample_concnm.updated_nm.connect(correct_concentration_ng)
	$Column4.add_child(sample_concnm)
	var sample_nmunit = new_sample_concmol.instantiate()
	sample_nmunit.row = row_number
	sample_nmunit.updated_units.connect(correct_units_nm)
	$Column45.add_child(sample_nmunit)
	var sample_libperc = new_sample_libperc.instantiate()
	sample_libperc.row = row_number
	$Column5.add_child(sample_libperc)
	var sample_vol = new_sample_vol.instantiate()
	sample_vol.row = row_number
	$Column6.add_child(sample_vol)
	sample_button.pressed_custom.connect(_button_pressed)
	for obj in get_children():
		if obj.name != \"Column0\":
			if obj.find_child(\"PhiX\") != null:
				obj.move_child(obj.get_node(\"PhiX\"), -1)
	update_dict()
	
func _button_pressed( row : int ):
	if row == 1:
		_spawn_row()
	else:
		for obj in self.get_children():
			for i in obj.get_children():
				if \"row\" in i and i.row == row:
					i.queue_free()
					break
		var label_num :int = 0
		for b in $Column0.get_children():
			if b is Button:
				b.text = label_num
				label_num += 1
		update_dict()
"

