[gd_scene load_steps=2 format=3 uid="uid://dmaut55q1w64"]

[sub_resource type="GDScript" id="GDScript_oxwt0"]
script/source = "extends LineEdit

@export var row : int

var previous_index : int = 1

signal updated_units

func _on_option_button_item_selected( index: int ) -> void:
	updated_units.emit( self.row, previous_index, index )
	previous_index = index
"

[node name="MassUnit" type="LineEdit"]
custom_minimum_size = Vector2(80, 40)
editable = false
script = SubResource("GDScript_oxwt0")

[node name="OptionButton" type="OptionButton" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
selected = 0
item_count = 2
popup/item_0/text = "ng/μL"
popup/item_0/id = 1
popup/item_1/text = "pg/μL"
popup/item_1/id = 2

[connection signal="item_selected" from="OptionButton" to="." method="_on_option_button_item_selected"]
