[gd_scene load_steps=2 format=3 uid="uid://c1hq1sbx10y1j"]

[sub_resource type="GDScript" id="GDScript_7nty7"]
script/source = "extends Button

@export var row : int
@onready var spreadsheet: HBoxContainer = $\"../..\"

var dragging : bool

var oldrow : int
var newrow : int

func _ready() -> void:
	self.dragging = false
	self.text = str(self.row)
	
func rearrange_rows() -> void:
	for obj in spreadsheet.get_children():
		if obj.name != \"Column0\":
			for item in obj.get_children():
				if \"row\" in item and item is not Label:
					if item.row == newrow:
						item.row = oldrow
					elif item.row == oldrow:
						item.row = newrow
			for item in obj.get_children():
				if \"row\" in item and item is not Label:
					if item is Button:
						if \"oldrow\" in item:
							item.text = item.row
						elif item.row == 1:
							item.text = \"+\"
							item[\"theme_override_styles/normal\"].bg_color = Color(0.25, 0.56, 0.78)
						else:
							item.text = '-'
							#item.set_modulate(Color(1,1,1))
							item[\"theme_override_styles/normal\"].bg_color = Color(0.6, 0.084, 0.084)
					obj.move_child(item, item.row)

func _on_button_down() -> void:
	self.dragging = true
	Buttondrag.dragging = true
	Buttondrag.current_button = self
	oldrow = self.row

func _on_button_up() -> void:
	self.dragging = false
	Buttondrag.dragging = false
	if Buttondrag.target_button != null:
		newrow = Buttondrag.target_button.row
		rearrange_rows()
		Buttondrag.target_button = null
		Buttondrag.current_button = null
		get_parent().get_parent().update_dict()
	
func _on_mouse_entered() -> void:
	if !self.dragging:
		Buttondrag.target_button = self

func _on_mouse_exited() -> void:
	Buttondrag.target_button = null
		
"

[node name="Sample1" type="Button"]
custom_minimum_size = Vector2(40, 40)
theme_override_colors/font_color = Color(1, 1, 1, 1)
text = "1
"
script = SubResource("GDScript_7nty7")

[node name="RichTextLabel" type="RichTextLabel" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 1
theme_override_colors/default_color = Color(0, 0, 0, 0)
bbcode_enabled = true
text = "[hint=\"Click and drag to rearrange columns.\"]FILLERFILLERFILLERFILLER[/hint]"
scroll_active = false
horizontal_alignment = 1
vertical_alignment = 1

[connection signal="button_down" from="." to="." method="_on_button_down"]
[connection signal="button_up" from="." to="." method="_on_button_up"]
[connection signal="mouse_entered" from="." to="." method="_on_mouse_entered"]
[connection signal="mouse_exited" from="." to="." method="_on_mouse_exited"]
