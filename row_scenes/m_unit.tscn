[gd_scene load_steps=2 format=3 uid="uid://c7dyenoii20m0"]

[sub_resource type="GDScript" id="GDScript_h7pwj"]
script/source = "extends LineEdit

@export var row : int

var previous_index : int = 1

signal updated_units

func _on_option_button_item_selected( index: int ) -> void:
	updated_units.emit( self.row, previous_index, index )
	previous_index = index
"

[node name="MUnit" type="LineEdit"]
custom_minimum_size = Vector2(0, 40)
size_flags_horizontal = 0
editable = false
script = SubResource("GDScript_h7pwj")

[node name="OptionButton" type="OptionButton" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
selected = 1
item_count = 3
popup/item_0/text = "μM"
popup/item_0/id = 1
popup/item_1/text = "nM"
popup/item_1/id = 2
popup/item_2/text = "pM"
popup/item_2/id = 3

[connection signal="item_selected" from="OptionButton" to="." method="_on_option_button_item_selected"]
