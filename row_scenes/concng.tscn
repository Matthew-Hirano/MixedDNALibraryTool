[gd_scene load_steps=2 format=3 uid="uid://d0jobwikrpods"]

[sub_resource type="GDScript" id="GDScript_4rc0c"]
script/source = "extends LineEdit

@export var row : int

signal updated_ng

func _on_text_submitted(_new_text: String) -> void:
	updated_ng.emit( self.row )

func _on_text_changed(_new_text: String) -> void:
	updated_ng.emit( self.row )
"

[node name="Sample1" type="LineEdit"]
custom_minimum_size = Vector2(0, 40)
theme_override_colors/font_color = Color(1, 1, 1, 1)
placeholder_text = "0.00"
script = SubResource("GDScript_4rc0c")

[connection signal="text_changed" from="." to="." method="_on_text_changed"]
[connection signal="text_submitted" from="." to="." method="_on_text_submitted"]
